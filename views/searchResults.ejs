<%- include('partials/head') %>

  <body>
    <!-- Background -->
    <div class="bg-layer">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
      <div class="grid-lines"></div>
    </div>

    <%- include('partials/header') %>

      <main class="topics-page">
        <div class="topics-container">
            <h2 class="section-title">
                  <span class="title-icon">&#9733;</span>
                  Результаты поиска
                </h2>
    
            <!-- Filters 
            <div class="topics-filters">
              <div class="filter-group">
                <label class="filter-label">Категория</label>
                <select class="filter-select" id="categoryFilter">
                  <option value="">Все категории</option>
                  <% categories.forEach(categorie=> { %>
                    <option value="<%= categorie.id %>">
                      <%= categorie.name %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <div class="filter-group">
                <label class="filter-label">Категория</label>
                <div class="section-tabs">
                  <a href="/searchResults?sort=new" class="tab <%= sort === 'new' ? 'active' : '' %>">Новые</a>
                  <a href="/searchResults?sort=popular" class="tab <%= sort === 'popular' ? 'active' : '' %>">Популярные</a>
                  <a href="/searchResults?sort=empty" class="tab <%= sort === 'empty' ? 'active' : '' %>">Не популярные</a>
                </div>
              </div>
            </div>
          </div>-->

          <!-- Topics List -->
          <div class="topics-list-container">
            <div class="topics-list-header">
              <span class="header-cell topic-cell">Тема</span>
              <span class="header-cell category-cell">Раздел</span>
              <span class="header-cell replies-cell">Ответы</span>
              <span class="header-cell replies-cell"></span>
              <span class="header-cell activity-cell">Автор</span>
            </div>

            <div class="topics-list-body">

              <!-- Regular Topics -->
              <% selectTopics.forEach(top=> { %>
                <div class="topic-list-row">
                  <div class="topic-cell">
                    <div class="topic-avatar">
                      <div class="avatar-circle" style="--hue: 270;">
                        <%= top.title[0].toUpperCase() %>
                      </div>
                    </div>
                    <div class="topic-main-info">
                      <a href="/topic/<%= top.id %>" class="topic-title-text">
                        <%= top.title %>
                      </a>
                      <div class="topic-meta-row">
                        <div class="topic-badges">
                          <span class="topic-category-badge" style="--cat-color: #f755a6;">
                            <%= top.description %>
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="category-cell">
                    <span class="category-tag" style="--cat-color: #f59e0b;">
                     <%= top.category_name %>
                    </span>
                  </div>
                  <div class="replies-cell">
                    <span class="stat-number">
                       <%= top.posts_count %>
                    </span>
                  </div>
                  <div class="activity-cell">
                    <div class="last-activity">

                    </div>
                  </div>
                  <div class="activity-cell">
                    <div class="last-activity">
                      <div class="last-user-avatar" style="--hue: 330;">
                          <%= top.author_name[0].toUpperCase() %>
                      </div>
                      <span class="last-activity-time">
                        <%= new Date(top.created_at).toLocaleString('ru-RU') %>
                      </span>
                    </div>
                  </div>


                </div>
                <% }) %>
            </div>
          </div>

          <!-- Pagination -->
          <div class="pagination-container">
            <div class="pagination-info">
              Показано 1-12 из 12,847 тем
            </div>
            <div class="pagination-controls">
              <button class="pagination-btn disabled">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="15 18 9 12 15 6" />
                </svg>
              </button>
              <button class="pagination-btn active">1</button>
              <button class="pagination-btn">2</button>
              <button class="pagination-btn">3</button>
              <span class="pagination-dots">...</span>
              <button class="pagination-btn">1071</button>
              <button class="pagination-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="9 18 15 12 9 6" />
                </svg>
              </button>
            </div>
            <div class="per-page-selector">
              <span>Показывать:</span>
              <select class="per-page-select">
                <option value="12" selected>12</option>
                <option value="24">24</option>
                <option value="48">48</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Add Event Modal -->
        <div class="modal-overlay" id="topic-modal" onclick="closeModalOnOverlay(event)">
          <div class="modal-content">
            <div class="modal-header">
              <h3 id="modal-title">Добавить событие</h3>
              <button class="modal-close" onclick="closeCreateTopicModal()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18" />
                  <line x1="6" y1="6" x2="18" y2="18" />
                </svg>
              </button>
            </div>
            <form id="topic-form" method='POST' action='/modalCreateTopic'>

              <div class="form-group">
                <label for="event-name">Название топика</label>
                <input type="text" id="title" name="title" class="form-input" required>
              </div>

              <div class="form-group">
                <label for="event-name">Описание</label>
                <input type="text" id="description" name="description" class="form-input" required>
              </div>

              <div class="form-group">
                <label for="category-parent">Категория</label>
                <select id="category-parent-add" name="category_id" class="form-input">
                  <% categories.forEach(categorie=> { %>
                    <option value="<%= categorie.id %>">
                      <%= categorie.name %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  <span id="modal-submit-text">Создать</span>
                </button>
                <button type="button" class="btn btn-secondary" onclick="closeCreateTopicModal()">
                  Отмена
                </button>
              </div>
            </form>
          </div>
        </div>
      </main>

      <%- include('partials/footer') %>