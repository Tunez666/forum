                  <button class="action-btn reject" title="Отклонить">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="6" x2="6" y2="18"/>
                      <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </section>

          <!-- New Users -->
          <section class="dashboard-card users-card">
            <div class="card-header">
              <h2 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="8.5" cy="7" r="4"/>
                  <line x1="20" y1="8" x2="20" y2="14"/>
                  <line x1="23" y1="11" x2="17" y2="11"/>
                </svg>
                Новые пользователи
              </h2>
              <a href="#users" class="card-link">Все пользователи &rarr;</a>
            </div>
            
            <div class="users-list">
              <!-- TODO: Пользователи из БД -->
              <div class="user-item">
                <div class="user-avatar" style="--hue: 320;">S</div>
