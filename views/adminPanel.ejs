              <div class="user-item">
                <div class="user-avatar" style="--hue: 180;">K</div>
                <div class="user-info">
                  <span class="user-name">KuroNeko</span>
                  <span class="user-email">kuro***@gmail.com</span>
                </div>
                <span class="user-date">Сегодня, 13:18</span>
              </div>

              <div class="user-item">
                <div class="user-avatar" style="--hue: 45;">A</div>
                <div class="user-info">
                  <span class="user-name">AchieronFan</span>
                  <span class="user-email">ache***@yandex.ru</span>
                </div>
                <span class="user-date">Сегодня, 12:05</span>
              </div>

              <div class="user-item">
                <div class="user-avatar" style="--hue: 270;">F</div>
                <div class="user-info">
                  <span class="user-name">FireflyBest</span>
                  <span class="user-email">fire***@outlook.com</span>
                </div>
                <span class="user-date">Сегодня, 10:47</span>
              </div>

              <div class="user-item">
                <div class="user-avatar" style="--hue: 100;">R</div>
                <div class="user-info">
                  <span class="user-name">RobinSinger</span>
                  <span class="user-email">robi***@mail.ru</span>
                </div>
                <span class="user-date">Вчера, 23:12</span>
              </div>
            </div>
          </section>

          <!-- Activity Chart Placeholder -->
          <section class="dashboard-card chart-card">
            <div class="card-header">
              <h2 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="20" x2="18" y2="10"/>
                  <line x1="12" y1="20" x2="12" y2="4"/>
                  <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
