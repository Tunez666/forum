                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="6" x2="6" y2="18"/>
                      <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </button>
                </div>
              </div>

              <div class="report-item">
                <div class="report-type offensive">Оскорбление</div>
                <div class="report-info">
                  <span class="report-target">Пользователь ToxicPlayer</span>
                  <span class="report-meta">от <strong>StarDust</strong> • 12 мин назад</span>
                </div>
                <div class="report-actions">
                  <button class="action-btn approve" title="Принять">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="20 6 9 17 4 12"/>
