<%- include('../partials/head') %>
<body>
  <!-- Animated Background -->
  <div class="bg-layer">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-lines"></div>
  </div>
  <!-- Admin Layout -->
  <div class="admin-layout">
    <!-- Sidebar -->
    <%- include('../partials/adminSidebar') %>
    <!-- Main Content -->
    <main class="admin-main">
      <!-- Header -->
      <header class="admin-header">
        <div class="header-left">
          <button class="sidebar-toggle" onclick="toggleSidebar()">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>

          <div class="page-title">
            <h1>Дашборд</h1>
            <span class="page-subtitle">Обзор статистики форума</span>
          </div>
        </div>

        <div class="header-right">
          <div class="header-search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" placeholder="Поиск..." class="search-input">
          </div>

          <!-- TODO: Реальные уведомления из БД -->
          <button class="notification-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            <span class="notification-dot"></span>
          </button>

          <a href="/" class="btn-back-site">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            На сайт
          </a>
        </div>
      </header>

      <!-- Dashboard Content -->
      <div class="admin-content">
        <!-- Stats Cards -->
        <section class="stats-grid">
          <!-- TODO: Получить реальные данные из БД -->
          <div class="stat-card">
            <div class="stat-icon users">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-value"><%= usersCount %></span>
              <span class="stat-label">Пользователей</span>
            </div>
            <div class="stat-trend up">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                <polyline points="17 6 23 6 23 12"/>
              </svg>
              +12.5%
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon topics">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-value"><%= topicsCount %></span>
              <span class="stat-label">Тем</span>
            </div>
            <div class="stat-trend up">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                <polyline points="17 6 23 6 23 12"/>
              </svg>
              +8.2%
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon posts">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-value"><%= postsCount %></span>
              <span class="stat-label">Сообщений</span>
            </div>
            <div class="stat-trend up">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                <polyline points="17 6 23 6 23 12"/>
              </svg>
              +15.3%
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon online">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-value">1,247</span>
              <span class="stat-label">Онлайн сейчас</span>
            </div>
            <div class="stat-trend down">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/>
                <polyline points="17 18 23 18 23 12"/>
              </svg>
              -3.1%
            </div>
          </div>
        </section>

        <!-- Content Grid -->
        <div class="dashboard-grid">
          <!-- Recent Reports -->
          <section class="dashboard-card reports-card">
            <div class="card-header">
              <h2 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
                  <line x1="4" y1="22" x2="4" y2="15"/>
                </svg>
                Последние жалобы
              </h2>
              <a href="#reports" class="card-link">Все жалобы &rarr;</a>
            </div>
            
            <div class="reports-list">
              <!-- TODO: Жалобы из БД -->
              <div class="report-item">
                <div class="report-type spam">Спам</div>
                <div class="report-info">
                  <span class="report-target">Сообщение #45872</span>
                  <span class="report-meta">от <strong>KafkaMains</strong> • 5 мин назад</span>
                </div>
                <div class="report-actions">
                  <button class="action-btn approve" title="Принять">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </button>
                  <button class="action-btn reject" title="Отклонить">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="6" x2="6" y2="18"/>
                      <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </button>
                </div>
              </div>

              <div class="report-item">
                <div class="report-type offensive">Оскорбление</div>
                <div class="report-info">
                  <span class="report-target">Пользователь ToxicPlayer</span>
                  <span class="report-meta">от <strong>StarDust</strong> • 12 мин назад</span>
                </div>
                <div class="report-actions">
                  <button class="action-btn approve" title="Принять">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </button>
                  <button class="action-btn reject" title="Отклонить">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="6" x2="6" y2="18"/>
                      <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </button>
                </div>
              </div>

              <div class="report-item">
                <div class="report-type other">Другое</div>
                <div class="report-info">
                  <span class="report-target">Тема "Баг в игре..."</span>
                  <span class="report-meta">от <strong>BladeMaster</strong> • 28 мин назад</span>
                </div>
                <div class="report-actions">
                  <button class="action-btn approve" title="Принять">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </button>
                  <button class="action-btn reject" title="Отклонить">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="6" x2="6" y2="18"/>
                      <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </button>
                </div>
              </div>

              <div class="report-item">
                <div class="report-type spam">Спам</div>
                <div class="report-info">
                  <span class="report-target">Сообщение #45869</span>
                  <span class="report-meta">от <strong>MarchSimp</strong> • 45 мин назад</span>
                </div>
                <div class="report-actions">
                  <button class="action-btn approve" title="Принять">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                  </button>
                  <button class="action-btn reject" title="Отклонить">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="18" y1="6" x2="6" y2="18"/>
                      <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </section>

          <!-- New Users -->
          <section class="dashboard-card users-card">
            <div class="card-header">
              <h2 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="8.5" cy="7" r="4"/>
                  <line x1="20" y1="8" x2="20" y2="14"/>
                  <line x1="23" y1="11" x2="17" y2="11"/>
                </svg>
                Новые пользователи
              </h2>
              <a href="#users" class="card-link">Все пользователи &rarr;</a>
            </div>
            
            <div class="users-list">
  <% users.forEach(user => { %>

    <div class="user-item">
      <div class="user-avatar" style="--hue: 320;">
        <%= user.username[0].toUpperCase() %>
      </div>

      <div class="user-info">
        <span class="user-name"><%= user.username %></span>
        <span class="user-email">
          <%= user.email.replace(/(.{3}).+(@.+)/, "$1***$2") %>
        </span>
      </div>

      <span class="user-date">
        <%= new Date(user.created_at).toLocaleString("ru-RU") %>
      </span>
    </div>

  <% }) %>
</div>
          </section>

          <!-- Activity Chart Placeholder -->
          <section class="dashboard-card chart-card">
            <div class="card-header">
              <h2 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="20" x2="18" y2="10"/>
                  <line x1="12" y1="20" x2="12" y2="4"/>
                  <line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                Активность за неделю
              </h2>
              <div class="chart-tabs">
                <button class="chart-tab active">Сообщения</button>
                <button class="chart-tab">Регистрации</button>
              </div>
            </div>
            
            <!-- TODO: Подключи реальный график (Chart.js или подобное) -->
            <div class="chart-placeholder">
              <div class="chart-bars">
                <div class="chart-bar-group">
                  <div class="chart-bar" style="--height: 45%;"></div>
                  <span class="chart-label">Пн</span>
                </div>
                <div class="chart-bar-group">
                  <div class="chart-bar" style="--height: 65%;"></div>
                  <span class="chart-label">Вт</span>
                </div>
                <div class="chart-bar-group">
                  <div class="chart-bar" style="--height: 85%;"></div>
                  <span class="chart-label">Ср</span>
                </div>
                <div class="chart-bar-group">
                  <div class="chart-bar" style="--height: 55%;"></div>
                  <span class="chart-label">Чт</span>
                </div>
                <div class="chart-bar-group">
                  <div class="chart-bar" style="--height: 75%;"></div>
                  <span class="chart-label">Пт</span>
                </div>
                <div class="chart-bar-group">
                  <div class="chart-bar active" style="--height: 95%;"></div>
                  <span class="chart-label">Сб</span>
                </div>
                <div class="chart-bar-group">
                  <div class="chart-bar" style="--height: 70%;"></div>
                  <span class="chart-label">Вс</span>
                </div>
              </div>
            </div>
          </section>

          <!-- Quick Actions -->
          <section class="dashboard-card actions-card">
            <div class="card-header">
              <h2 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
                Быстрые действия
              </h2>
            </div>
            
            <div class="quick-actions">
              <!-- TODO: Добавь обработчики для каждого действия -->
              <button class="quick-action-btn">
                <div class="action-icon create">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                </div>
                <span>Создать категорию</span>
              </button>

              <button class="quick-action-btn">
                <div class="action-icon announce">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/>
                  </svg>
                </div>
                <span>Отправить новость</span>
              </button>

              <button class="quick-action-btn">
                <div class="action-icon ban">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                  </svg>
                </div>
                <span>Забанить пользователя</span>
              </button>

              <button class="quick-action-btn">
                <div class="action-icon backup">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="21 8 21 21 3 21 3 8"/>
                    <rect x="1" y="3" width="22" height="5"/>
                  </svg>
                </div>
                <span>Создать бэкап</span>
              </button>
            </div>
          </section>

          <!-- Recent Activity Log -->
          <section class="dashboard-card log-card">
            <div class="card-header">
              <h2 class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                Последние действия
              </h2>
              <a href="#logs" class="card-link">Все логи &rarr;</a>
            </div>
            
            <div class="activity-log">
              <!-- TODO: Логи из БД -->
              <div class="log-item">
                <div class="log-icon edit">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                  </svg>
                </div>
                <div class="log-content">
                  <span class="log-text"><strong>Admin</strong> изменил настройки форума</span>
                  <span class="log-time">2 минуты назад</span>
                </div>
              </div>

              <div class="log-item">
                <div class="log-icon delete">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                  </svg>
                </div>
                <div class="log-content">
                  <span class="log-text"><strong>Moderator</strong> удалил сообщение #45867</span>
                  <span class="log-time">15 минут назад</span>
                </div>
              </div>

              <div class="log-item">
                <div class="log-icon ban">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>
                  </svg>
                </div>
                <div class="log-content">
                  <span class="log-text"><strong>Admin</strong> забанил пользователя SpamBot123</span>
                  <span class="log-time">32 минуты назад</span>
                </div>
              </div>

              <div class="log-item">
                <div class="log-icon create">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                </div>
                <div class="log-content">
                  <span class="log-text"><strong>Admin</strong> создал новую категорию "События"</span>
                  <span class="log-time">1 час назад</span>
                </div>
              </div>

              <div class="log-item">
                <div class="log-icon approve">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                <div class="log-content">
                  <span class="log-text"><strong>Moderator</strong> одобрил жалобу на сообщение</span>
                  <span class="log-time">2 часа назад</span>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
