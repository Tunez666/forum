    </main>
  </div>

  <!-- Edit Topic Modal -->
  <div class="modal-overlay" id="edit-modal">
    <div class="modal-content modal-lg">
      <div class="modal-header">
        <h3>Редактировать тему</h3>
        <button class="modal-close" onclick="closeEditModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      
      <form id="edit-topic-form">
        <input type="hidden" id="edit-topic-id" name="id">
        
        <div class="modal-body">
          <div class="form-group">
            <label for="edit-topic-title">Название темы *</label>
            <input type="text" id="edit-topic-title" name="title" class="form-input" required>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="edit-topic-category">Категория</label>
              <select id="edit-topic-category" name="category_id" class="form-input">
                <!-- TODO: Загрузить категории из БД -->
                <option value="1">Общее обсуждение</option>
                <option value="2">Персонажи</option>
                <option value="3">Гайды</option>
                <option value="4">Творчество</option>
                <option value="5">Оффтоп</option>
              </select>
            </div>

            <div class="form-group">
              <label for="edit-topic-author">Автор</label>
              <input type="text" id="edit-topic-author" name="author" class="form-input" readonly>
            </div>
          </div>

          <div class="form-group">
            <label>Статус темы</label>
            <div class="checkbox-group horizontal">
              <label class="checkbox-label">
                <input type="checkbox" name="is_pinned" id="edit-is-pinned">
                <span class="checkmark"></span>
                <span>Закрепить</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="is_closed" id="edit-is-closed">
                <span class="checkmark"></span>
                <span>Закрыть</span>
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="is_hidden" id="edit-is-hidden">
                <span class="checkmark"></span>
                <span>Скрыть</span>
              </label>
            </div>
          </div>

          <div class="form-group">
            <label for="edit-topic-note">Заметка модератора</label>
            <textarea id="edit-topic-note" name="mod_note" class="form-textarea" placeholder="Причина изменений (видна только модераторам)..." rows="2"></textarea>
          </div>
        </div>

        <div class="modal-footer">
          <!-- TODO: Добавить обработчик сохранения -->
          <button type="submit" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
              <polyline points="17 21 17 13 7 13 7 21"/>
              <polyline points="7 3 7 8 15 8"/>
            </svg>
            Сохранить
          </button>
          <button type="button" class="btn btn-secondary" onclick="closeEditModal()">
            Отмена
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Move Topic Modal -->
  <div class="modal-overlay" id="move-modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3>Переместить темы</h3>
        <button class="modal-close" onclick="closeMoveModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      
      <div class="modal-body">
        <p class="modal-description">Выберите категорию для перемещения <strong id="move-count">0</strong> тем:</p>
        
        <div class="form-group">
          <label for="move-category">Категория назначения</label>
          <select id="move-category" class="form-input">
            <!-- TODO: Загрузить категории из БД -->
            <option value="1">Общее обсуждение</option>
            <option value="2">Персонажи</option>
            <option value="3">Гайды</option>
            <option value="4">Творчество</option>
            <option value="5">Оффтоп</option>
          </select>
        </div>
      </div>

      <div class="modal-footer">
        <!-- TODO: Добавить обработчик перемещения -->
        <button type="button" class="btn btn-primary" onclick="confirmMove()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
          </svg>
          Переместить
        </button>
        <button type="button" class="btn btn-secondary" onclick="closeMoveModal()">
          Отмена
        </button>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="modal-overlay" id="delete-modal">
    <div class="modal-content modal-sm">
      <div class="modal-header danger">
        <h3>Удаление темы</h3>
        <button class="modal-close" onclick="closeDeleteModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      
      <div class="modal-body">
        <div class="delete-warning">
          <div class="warning-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <p>Вы уверены, что хотите удалить <span id="delete-count">эту тему</span>?</p>
          <p class="warning-text">Все сообщения в теме также будут удалены. Это действие нельзя отменить.</p>
        </div>
      </div>

      <div class="modal-footer">
        <!-- TODO: Добавить обработчик удаления -->
        <button type="button" class="btn btn-danger" onclick="confirmDelete()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"/>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
          </svg>
          Да, удалить
        </button>
        <button type="button" class="btn btn-secondary" onclick="closeDeleteModal()">
          Отмена
        </button>
      </div>
    </div>
  </div>

  <!-- Toast Container -->
  <div class="toast-container" id="toast-container"></div>

  <script>


    // ============================================
    // Selection Management
    // ============================================
    let selectedTopics = new Set();

    function toggleSelectAll() {
      const selectAll = document.getElementById('select-all');
      const checkboxes = document.querySelectorAll('.topic-checkbox');
      
      checkboxes.forEach(cb => {
        cb.checked = selectAll.checked;
        if (selectAll.checked) {
          selectedTopics.add(cb.value);
        } else {
          selectedTopics.delete(cb.value);
        }
      });
      
      updateBulkActions();
    }

    function updateSelection() {
      const checkboxes = document.querySelectorAll('.topic-checkbox');
      const selectAll = document.getElementById('select-all');
      
      selectedTopics.clear();
      checkboxes.forEach(cb => {
        if (cb.checked) {
          selectedTopics.add(cb.value);
        }
      });
      
      // Update "select all" checkbox state
      const allChecked = Array.from(checkboxes).every(cb => cb.checked);
      const someChecked = Array.from(checkboxes).some(cb => cb.checked);
      selectAll.checked = allChecked;
      selectAll.indeterminate = someChecked && !allChecked;
      
      updateBulkActions();
    }

    function updateBulkActions() {
      const bulkActions = document.getElementById('bulk-actions');
      const countSpan = document.getElementById('selected-count');
      
      countSpan.textContent = selectedTopics.size;
      
      if (selectedTopics.size > 0) {
        bulkActions.style.display = 'flex';
      } else {
        bulkActions.style.display = 'none';
      }
    }

    // ============================================
    // Bulk Actions
    // ============================================
    function bulkPin() {
      // TODO: Закрепить выбранные темы в БД
      console.log('Pinning topics:', Array.from(selectedTopics));
      showToast(`${selectedTopics.size} тем закреплено`, 'success');
      clearSelection();
    }

    function bulkClose() {
      // TODO: Закрыть выбранные темы в БД
      console.log('Closing topics:', Array.from(selectedTopics));
      showToast(`${selectedTopics.size} тем закрыто`, 'success');
      clearSelection();
    }

    function bulkMove() {
      document.getElementById('move-count').textContent = selectedTopics.size;
      document.getElementById('move-modal').classList.add('active');
    }

    function bulkDelete() {
      document.getElementById('delete-count').textContent = `${selectedTopics.size} тем`;
      deleteTopicIds = Array.from(selectedTopics);
      document.getElementById('delete-modal').classList.add('active');
    }

    function clearSelection() {
      selectedTopics.clear();
      document.querySelectorAll('.topic-checkbox').forEach(cb => cb.checked = false);
      document.getElementById('select-all').checked = false;
      updateBulkActions();
    }

    // ============================================
    // Single Topic Actions
    // ============================================
    function pinTopic(id) {
      // TODO: Закрепить тему в БД
      const row = document.querySelector(`[data-topic-id="${id}"]`);
      row.classList.add('pinned');
      showToast('Тема закреплена', 'success');
    }

    function unpinTopic(id) {
      // TODO: Открепить тему в БД
      const row = document.querySelector(`[data-topic-id="${id}"]`);
      row.classList.remove('pinned');
      showToast('Тема откреплена', 'success');
    }

    function openTopic(id) {
      // TODO: Открыть тему в БД
      const row = document.querySelector(`[data-topic-id="${id}"]`);
      row.classList.remove('closed');
      showToast('Тема открыта', 'success');
    }

    function showTopic(id) {
      // TODO: Показать тему в БД
      const row = document.querySelector(`[data-topic-id="${id}"]`);
      row.classList.remove('hidden-topic');
      showToast('Тема показана', 'success');
    }

    // ============================================
    // Edit Modal
    // ============================================
    let currentEditId = null;

    function editTopic(id) {
      currentEditId = id;
      
      // TODO: Загрузить данные темы из БД
      // Заглушка:
      document.getElementById('edit-topic-id').value = id;
      document.getElementById('edit-topic-title').value = 'Название темы ' + id;
      document.getElementById('edit-topic-author').value = 'Author' + id;
      
      document.getElementById('edit-modal').classList.add('active');
    }

    function closeEditModal() {
      document.getElementById('edit-modal').classList.remove('active');
      currentEditId = null;
    }

    document.getElementById('edit-topic-form').addEventListener('submit', function(e) {
      e.preventDefault();
      
      // TODO: Сохранить изменения в БД
      showToast('Тема обновлена', 'success');
      closeEditModal();
    });

    // ============================================
    // Move Modal
    // ============================================
    function closeMoveModal() {
      document.getElementById('move-modal').classList.remove('active');
    }

    function confirmMove() {
      const categoryId = document.getElementById('move-category').value;
      
      // TODO: Переместить темы в БД
      console.log('Moving topics to category:', categoryId);
      
      showToast(`${selectedTopics.size} тем перемещено`, 'success');
      closeMoveModal();
      clearSelection();
    }

    // ============================================
    // Delete Modal
    // ============================================
    let deleteTopicIds = [];

    function deleteTopic(id) {
      deleteTopicIds = [id];
      document.getElementById('delete-count').textContent = 'эту тему';
      document.getElementById('delete-modal').classList.add('active');
    }

    function closeDeleteModal() {
      document.getElementById('delete-modal').classList.remove('active');
      deleteTopicIds = [];
    }

    function confirmDelete() {
      // TODO: Удалить темы из БД
      console.log('Deleting topics:', deleteTopicIds);
      
      deleteTopicIds.forEach(id => {
        const row = document.querySelector(`[data-topic-id="${id}"]`);
        if (row) {
          row.style.animation = 'fadeOut 0.3s ease forwards';
          setTimeout(() => row.remove(), 300);
        }
      });
      
      showToast(`${deleteTopicIds.length > 1 ? deleteTopicIds.length + ' тем удалено' : 'Тема удалена'}`, 'success');
      closeDeleteModal();
      clearSelection();
    }

    // ============================================
    // Search and Filters
    // ============================================
    document.getElementById('search-topics').addEventListener('input', function(e) {
      const query = e.target.value.toLowerCase();
      const rows = document.querySelectorAll('.topic-row');
      
      rows.forEach(row => {
        const title = row.querySelector('.topic-title').textContent.toLowerCase();
        const author = row.querySelector('.author-name').textContent.toLowerCase();
        
        if (title.includes(query) || author.includes(query)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });

    document.getElementById('filter-category').addEventListener('change', filterTopics);
    document.getElementById('filter-status').addEventListener('change', filterTopics);
    document.getElementById('filter-sort').addEventListener('change', filterTopics);

    function filterTopics() {
      // TODO: Фильтровать темы через API
      console.log('Filtering topics...');
    }

    // ============================================
    // Export
    // ============================================
    function exportTopics() {
      // TODO: Экспорт тем в CSV/Excel
      showToast('Экспорт начат...', 'info');
    }

    // ============================================
    // Toast Notifications
    // ============================================
    function showToast(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = `toast toast-${type}`;
      
      const icons = {
        success: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
        error: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
        info: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>'
      };
      
      toast.innerHTML = `
        <span class="toast-icon">${icons[type]}</span>
        <span class="toast-message">${message}</span>
      `;
      
      container.appendChild(toast);
      setTimeout(() => toast.classList.add('show'), 10);
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    // Закрытие модалок
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', function(e) {
        if (e.target === this) {
          this.classList.remove('active');
        }
      });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.querySelectorAll('.modal-overlay.active').forEach(modal => {
          modal.classList.remove('active');
        });
      }
    });
  </script>
</body>
