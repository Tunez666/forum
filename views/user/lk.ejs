            <script>


                // ============================================
                // Avatar Upload Widget
                // ============================================

                const avatarInput = document.getElementById('avatarInput');
                const avatarPreview = document.getElementById('avatarPreview');
                const avatarImage = document.getElementById('avatarImage');
                const sidebarAvatar = document.getElementById('sidebarAvatar');

                avatarPreview.addEventListener('click', () => {
                    avatarInput.click();
                });

                avatarInput.addEventListener('change', function (e) {
                    const file = e.target.files[0];
                    if (!file) return;

                    if (file.size > 2 * 1024 * 1024) {
                        showToast('Файл слишком большой. Максимум 2MB.', 'error');
                        return;
                    }

                    if (!file.type.startsWith('image/')) {
                        showToast('Можно загружать только изображения.', 'error');
                        return;
                    }

                    const reader = new FileReader();
                    reader.onload = function (e) {
                        avatarImage.src = e.target.result;
                        sidebarAvatar.src = e.target.result;
                    };

                    reader.readAsDataURL(file);
                });

                function removeAvatar() {
                    const defaultAvatar =
                        'https://api.dicebear.com/7.x/avataaars/svg?seed=Default';

                    avatarImage.src = defaultAvatar;
                    sidebarAvatar.src = defaultAvatar;

                    avatarInput.value = "";
                }
                // ============================================
                // Remove avatar (UI + optional server call)
                // ============================================
                function removeAvatar() {
                    const defaultAvatar =
                        'https://api.dicebear.com/7.x/avataaars/svg?seed=Default';

                    avatarImage.src = defaultAvatar;
                    sidebarAvatar.src = defaultAvatar;

                    // reset input
                    avatarInput.value = "";
