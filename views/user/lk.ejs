                                                    <div class="chart-bar" style="--height: 85%"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Recent Activity -->
                                    <div class="section-card">
                                        <h3 class="card-title">Последняя активность</h3>
                                        <div class="activity-list">
                                            <div class="activity-item">
                                                <div class="activity-icon reply">
