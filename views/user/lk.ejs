                                    <!-- Delete Account -->
                                    <div class="section-card danger-zone">
                                        <h3 class="card-title danger">Опасная зона</h3>
                                        <p class="danger-description">Удаление аккаунта необратимо. Все ваши данные
                                            будут удалены.</p>
                                        <button class="btn btn-danger"
                                            onclick="openDeleteAccModal()">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path
                                                    d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                            </svg>
                                            Удалить аккаунт
                                        </button>
                                    </div>
                                </div>
                            </section>





                            <!-- Tab: Notifications -->
                            <section id="notifications" class="profile-tab">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                                            </svg>
                                            Уведомления
                                        </h2>
                                    </div>

                                    <div class="section-card">
                                        <h3 class="card-title">Email уведомления</h3>
                                        <div class="preferences-list">
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Ответы на темы</span>
                                                    <span class="preference-description">Когда кто-то отвечает в ваших
                                                        темах</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Упоминания</span>
                                                    <span class="preference-description">Когда вас упоминают через
                                                        @username</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Личные сообщения</span>
                                                    <span class="preference-description">Когда вам пишут в личные
                                                        сообщения</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Новости форума</span>
                                                    <span class="preference-description">Важные объявления и
                                                        обновления</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox">
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="section-card">
                                        <h3 class="card-title">Push-уведомления</h3>
                                        <div class="preferences-list">
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Браузерные уведомления</span>
                                                    <span class="preference-description">Получать уведомления в
                                                        браузере</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox">
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Звук уведомлений</span>
                                                    <span class="preference-description">Воспроизводить звук при новых
                                                        уведомлениях</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <!-- Tab: Stats -->
                            <section id="stats" class="profile-tab">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <line x1="18" y1="20" x2="18" y2="10" />
                                                <line x1="12" y1="20" x2="12" y2="4" />
                                                <line x1="6" y1="20" x2="6" y2="14" />
                                            </svg>
                                            Статистика активности
                                        </h2>
                                    </div>

                                    <!-- Stats Cards -->
                                    <div class="stats-grid">
                                        <div class="stat-card">
                                            <div class="stat-icon purple">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <path
                                                        d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                                </svg>
                                            </div>
                                            <div class="stat-content">
                                                <span class="stat-value">1,247</span>
                                                <span class="stat-label">Сообщений</span>
                                            </div>
                                        </div>
                                        <div class="stat-card">
                                            <div class="stat-icon pink">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <path
                                                        d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                                    <polyline points="14 2 14 8 20 8" />
                                                </svg>
                                            </div>
                                            <div class="stat-content">
                                                <span class="stat-value">56</span>
                                                <span class="stat-label">Тем создано</span>
                                            </div>
                                        </div>
                                        <div class="stat-card">
                                            <div class="stat-icon cyan">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <path
                                                        d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                                </svg>
                                            </div>
                                            <div class="stat-content">
                                                <span class="stat-value">3,891</span>
                                                <span class="stat-label">Получено лайков</span>
                                            </div>
                                        </div>
                                        <div class="stat-card">
                                            <div class="stat-icon gold">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <polygon
                                                        points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                                                </svg>
                                            </div>
                                            <div class="stat-content">
                                                <span class="stat-value">+842</span>
                                                <span class="stat-label">Репутация</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Activity Chart -->
                                    <div class="section-card">
                                        <h3 class="card-title">Активность за последние 30 дней</h3>
                                        <div class="activity-chart">
                                            <!-- TODO: Интегрировать библиотеку для графиков (Chart.js или Recharts) -->
                                            <div class="chart-placeholder">
                                                <div class="chart-bars">
