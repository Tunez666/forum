<%- include('../partials/head') %>

    <body>
        <!-- Animated Background -->
        <div class="animated-bg">
            <div class="grid-overlay"></div>
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
        </div>

        <%- include('../partials/header') %>

            <main class="profile-page">
                <div class="profile-container">

                    <%- include('../partials/userSidebar') %>

                        <!-- Main Content -->
                        <div class="profile-content">

                            <!-- Tab: General -->
                            <section id="general" class="profile-tab active">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                                <circle cx="12" cy="7" r="4" />
                                            </svg>
                                            Основная информация
                                        </h2>
                                    </div>

                                    <div class="section-card">
                                        <!-- Avatar Upload -->

                                        <div class="avatar-upload-section">
                                            <!-- Form Fields -->
                                            <form class="profile-form" id="generalForm" method='POST'
                                                action='/user/updateUserInfo' enctype="multipart/form-data">
                                                <div class="form-row">
                                                    <div class="avatar-preview" id="avatarPreview">
                                                        <img src="/img/avas/<%= userData.avatarca %>" alt="Аватар"
                                                            id="avatarImage">
                                                        <div class="avatar-overlay">
                                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <path
                                                                    d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                                                                <circle cx="12" cy="13" r="4" />
                                                            </svg>
                                                            <span>Изменить</span>
                                                        </div>
                                                        <input type="file" id="avatarInput" name="ava" accept="image/*"
                                                            hidden>
                                                    </div>
                                                    <div class="avatar-info">
                                                        <h4>Аватар профиля</h4>
                                                        <p>JPG, PNG или GIF. Максимум 2MB.</p>
                                                        <div class="avatar-buttons">
                                                            <button type="button" class="btn btn-primary btn-sm"
                                                                onclick="document.getElementById('avatarInput').click()">
                                                                Загрузить
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>


                                                <div class="form-group">
                                                    <label for="username">Имя пользователя</label>
                                                    <input type="text" id="username" class="form-input" name="username"
                                                        value="<%= userData.username %>" placeholder="Введите имя">
                                                    <span class="form-hint">Видно другим пользователям форума</span>
                                                </div>
                                                <div class="form-group">
                                                    <label for="uid">UID в игре</label>
                                                    <input type="text" id="uid" class="form-input" name="uid"
                                                        value="<%= userData.uid %>" placeholder="Введите UID">
                                                    <span class="form-hint">Для добавления в друзья в игре</span>
                                                </div>
                                        </div>

                                        <div class="form-group">
                                            <label for="bio">О себе</label>
                                            <textarea id="bio" class="form-textarea" name="about" rows="3"
                                                placeholder="Расскажите о себе..."><%= userData.about %></textarea>
                                            <span class="form-hint">Краткое описание для вашего профиля</span>
                                        </div>

                                        <div class="form-actions">
                                            <button type="submit" class="btn btn-primary">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <path
                                                        d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                                    <polyline points="17 21 17 13 7 13 7 21" />
                                                    <polyline points="7 3 7 8 15 8" />
                                                </svg>
                                                Сохранить изменения
                                            </button>
                                            <button type="reset" class="btn btn-ghost">Отменить</button>
                                        </div>
                                        </form>
                                    </div>
                                </div>
                            </section>

                            <!-- Tab: Security -->
                            <section id="security" class="profile-tab">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                            </svg>
                                            Безопасность
                                        </h2>
                                    </div>

                                    <!-- Change Password -->
                                    <div class="section-card">
                                        <h3 class="card-title">Изменить пароль</h3>
                                        <form class="profile-form" id="passwordForm" method='POST'
                                            action='/user/updatePass'>
                                            <div class="form-group">
                                                <label for="currentPassword">Текущий пароль</label>
                                                <div class="password-input-wrapper">
                                                    <input type="password" id="currentPassword" name="currentPass"
                                                        class="form-input" placeholder="Введите текущий пароль">
                                                    <button type="button" class="password-toggle"
                                                        onclick="togglePassword('currentPassword')">
                                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                            stroke="currentColor" stroke-width="2">
                                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                            <circle cx="12" cy="12" r="3" />
                                                        </svg>
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="newPassword">Новый пароль</label>
                                                    <div class="password-input-wrapper">
                                                        <input type="password" id="newPassword" name="newPass"
                                                            class="form-input" placeholder="Введите новый пароль">
                                                        <button type="button" class="password-toggle"
                                                            onclick="togglePassword('newPassword')">
                                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <path
                                                                    d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                                <circle cx="12" cy="12" r="3" />
                                                            </svg>
                                                        </button>
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <label for="confirmPassword">Подтвердите пароль</label>
                                                    <div class="password-input-wrapper">
                                                        <input type="password" id="confirmPassword" name="enterPass"
                                                            class="form-input" placeholder="Повторите новый пароль">
                                                        <button type="button" class="password-toggle"
                                                            onclick="togglePassword('confirmPassword')">
                                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <path
                                                                    d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                                <circle cx="12" cy="12" r="3" />
                                                            </svg>
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-actions">
                                                <button type="submit" class="btn btn-primary">Изменить пароль</button>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Two-Factor Auth -->
                                    <!--<div class="section-card">
                                        <div class="security-option">
                                            <div class="security-info">
                                                <div class="security-icon">
                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                                    </svg>
                                                </div>
                                                <div>
                                                    <h3 class="card-title">Двухфакторная аутентификация</h3>
                                                    <p class="security-description">Дополнительный уровень защиты вашего
                                                        аккаунта</p>
                                                </div>
                                            </div>
                                            <label class="toggle-switch">
                                                <input type="checkbox" id="twoFactorToggle">
                                                <span class="toggle-slider"></span>
                                            </label>
                                        </div>
                                    </div>-->

