<%- include('../partials/head') %>

    <body>
        <!-- Animated Background -->
        <div class="animated-bg">
            <div class="grid-overlay"></div>
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
        </div>

        <%- include('../partials/header') %>

            <main class="profile-page">
                <div class="profile-container">

                    <%- include('../partials/userSidebar') %>

                        <!-- Main Content -->
                        <div class="profile-content">

                            <!-- Tab: General -->
                            <section id="general" class="profile-tab active">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                                <circle cx="12" cy="7" r="4" />
                                            </svg>
                                            Основная информация
                                        </h2>
                                    </div>

                                    <div class="section-card">
                                        <!-- Avatar Upload -->

                                        <div class="avatar-upload-section">
                                            <!-- Form Fields -->
                                            <form class="profile-form" id="generalForm" method='POST'
                                                action='/user/updateUserInfo' enctype="multipart/form-data">
                                                <div class="form-row">
                                                    <div class="avatar-preview" id="avatarPreview">
                                                        <img src="/img/avas/<%= userData.avatarca %>"
                                                            alt="Аватар" id="avatarImage">
                                                        <div class="avatar-overlay">
                                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <path
                                                                    d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" />
                                                                <circle cx="12" cy="13" r="4" />
                                                            </svg>
                                                            <span>Изменить</span>
                                                        </div>
                                                        <input type="file" id="avatarInput" name="ava" accept="image/*"
                                                            hidden>
                                                    </div>
                                                    <div class="avatar-info">
                                                        <h4>Аватар профиля</h4>
                                                        <p>JPG, PNG или GIF. Максимум 2MB.</p>
                                                        <div class="avatar-buttons">
                                                            <button type="button" class="btn btn-primary btn-sm"
                                                                onclick="document.getElementById('avatarInput').click()">
                                                                Загрузить
                                                            </button>
                                                            <button class="btn btn-ghost btn-sm"
                                                                onclick="removeAvatar()">
                                                                Удалить
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>


                                                <div class="form-group">
                                                    <label for="username">Имя пользователя</label>
                                                    <input type="text" id="username" class="form-input" name="username"
                                                        value="<%= userData.username %>" placeholder="Введите имя">
                                                    <span class="form-hint">Видно другим пользователям форума</span>
                                                </div>
                                                <div class="form-group">
                                                    <label for="uid">UID в игре</label>
                                                    <input type="text" id="uid" class="form-input" name="uid"
                                                        value="<%= userData.uid %>" placeholder="Введите UID">
                                                    <span class="form-hint">Для добавления в друзья в игре</span>
                                                </div>
                                        </div>

                                        <div class="form-group">
                                            <label for="bio">О себе</label>
                                            <textarea id="bio" class="form-textarea" name="about" rows="3"
                                                placeholder="Расскажите о себе..."><%= userData.about %></textarea>
                                            <span class="form-hint">Краткое описание для вашего профиля</span>
                                        </div>

                                        <div class="form-actions">
                                            <button type="submit" class="btn btn-primary">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <path
                                                        d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                                    <polyline points="17 21 17 13 7 13 7 21" />
                                                    <polyline points="7 3 7 8 15 8" />
                                                </svg>
                                                Сохранить изменения
                                            </button>
                                            <button type="reset" class="btn btn-ghost">Отменить</button>
                                        </div>
                                        </form>
                                    </div>
                                </div>
                            </section>

                            <!-- Tab: Security -->
                            <section id="security" class="profile-tab">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                            </svg>
                                            Безопасность
                                        </h2>
                                    </div>

                                    <!-- Change Password -->
                                    <div class="section-card">
                                        <h3 class="card-title">Изменить пароль</h3>
                                        <form class="profile-form" id="passwordForm">
                                            <div class="form-group">
                                                <label for="currentPassword">Текущий пароль</label>
                                                <div class="password-input-wrapper">
                                                    <input type="password" id="currentPassword" class="form-input"
                                                        placeholder="Введите текущий пароль">
                                                    <button type="button" class="password-toggle"
                                                        onclick="togglePassword('currentPassword')">
                                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                            stroke="currentColor" stroke-width="2">
                                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                            <circle cx="12" cy="12" r="3" />
                                                        </svg>
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="form-row">
                                                <div class="form-group">
                                                    <label for="newPassword">Новый пароль</label>
                                                    <div class="password-input-wrapper">
                                                        <input type="password" id="newPassword" class="form-input"
                                                            placeholder="Введите новый пароль">
                                                        <button type="button" class="password-toggle"
                                                            onclick="togglePassword('newPassword')">
                                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <path
                                                                    d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                                <circle cx="12" cy="12" r="3" />
                                                            </svg>
                                                        </button>
                                                    </div>
                                                    <div class="password-strength" id="passwordStrength">
                                                        <div class="strength-bar"></div>
                                                        <span class="strength-text">Надежность пароля</span>
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <label for="confirmPassword">Подтвердите пароль</label>
                                                    <div class="password-input-wrapper">
                                                        <input type="password" id="confirmPassword" class="form-input"
                                                            placeholder="Повторите новый пароль">
                                                        <button type="button" class="password-toggle"
                                                            onclick="togglePassword('confirmPassword')">
                                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <path
                                                                    d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                                <circle cx="12" cy="12" r="3" />
                                                            </svg>
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-actions">
                                                <button type="submit" class="btn btn-primary">Изменить пароль</button>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Two-Factor Auth -->
                                    <div class="section-card">
                                        <div class="security-option">
                                            <div class="security-info">
                                                <div class="security-icon">
                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                                    </svg>
                                                </div>
                                                <div>
                                                    <h3 class="card-title">Двухфакторная аутентификация</h3>
                                                    <p class="security-description">Дополнительный уровень защиты вашего
                                                        аккаунта</p>
                                                </div>
                                            </div>
                                            <label class="toggle-switch">
                                                <input type="checkbox" id="twoFactorToggle">
                                                <span class="toggle-slider"></span>
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Active Sessions -->
                                    <div class="section-card">
                                        <h3 class="card-title">Активные сессии</h3>
                                        <div class="sessions-list">
                                            <div class="session-item current">
                                                <div class="session-icon">
                                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                                                        <line x1="8" y1="21" x2="16" y2="21" />
                                                        <line x1="12" y1="17" x2="12" y2="21" />
                                                    </svg>
                                                </div>
                                                <div class="session-info">
                                                    <span class="session-device">Windows - Chrome</span>
                                                    <span class="session-location">Москва, Россия • Текущая
                                                        сессия</span>
                                                </div>
                                                <span class="session-badge current">Текущая</span>
                                            </div>
                                            <div class="session-item">
                                                <div class="session-icon">
                                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <rect x="5" y="2" width="14" height="20" rx="2" ry="2" />
                                                        <line x1="12" y1="18" x2="12.01" y2="18" />
                                                    </svg>
                                                </div>
                                                <div class="session-info">
                                                    <span class="session-device">iPhone - Safari</span>
                                                    <span class="session-location">Москва, Россия • 2 часа назад</span>
                                                </div>
                                                <button class="btn btn-ghost btn-sm"
                                                    onclick="terminateSession(1)">Завершить</button>
                                            </div>
                                        </div>
                                        <button class="btn btn-danger btn-sm" onclick="terminateAllSessions()">
                                            Завершить все сессии
                                        </button>
                                    </div>

                                    <!-- Delete Account -->
                                    <div class="section-card danger-zone">
                                        <h3 class="card-title danger">Опасная зона</h3>
                                        <p class="danger-description">Удаление аккаунта необратимо. Все ваши данные
                                            будут удалены.</p>
                                        <button class="btn btn-danger" onclick="showDeleteAccountModal()">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path
                                                    d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                            </svg>
                                            Удалить аккаунт
                                        </button>
                                    </div>
                                </div>
                            </section>

                            <!-- Tab: Forum -->
                            <section id="forum" class="profile-tab">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path
                                                    d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                            </svg>
                                            Настройки форума
                                        </h2>
                                    </div>

                                    <!-- Signature -->
                                    <div class="section-card">
                                        <h3 class="card-title">Подпись на форуме</h3>
                                        <p class="card-description">Отображается под каждым вашим сообщением</p>
                                        <form class="profile-form" id="signatureForm">
                                            <div class="form-group">
                                                <div class="signature-editor">
                                                    <div class="editor-toolbar">
                                                        <button type="button" class="toolbar-btn"
                                                            onclick="formatText('bold')" title="Жирный">
                                                            <strong>B</strong>
                                                        </button>
                                                        <button type="button" class="toolbar-btn"
                                                            onclick="formatText('italic')" title="Курсив">
                                                            <em>I</em>
                                                        </button>
                                                        <button type="button" class="toolbar-btn"
                                                            onclick="formatText('underline')" title="Подчеркнутый">
                                                            <u>U</u>
                                                        </button>
                                                        <span class="toolbar-divider"></span>
                                                        <button type="button" class="toolbar-btn" onclick="insertLink()"
                                                            title="Ссылка">
                                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <path
                                                                    d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                                                                <path
                                                                    d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                                                            </svg>
                                                        </button>
                                                        <button type="button" class="toolbar-btn"
                                                            onclick="insertImage()" title="Изображение">
                                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                                stroke="currentColor" stroke-width="2">
                                                                <rect x="3" y="3" width="18" height="18" rx="2"
                                                                    ry="2" />
                                                                <circle cx="8.5" cy="8.5" r="1.5" />
                                                                <polyline points="21 15 16 10 5 21" />
                                                            </svg>
                                                        </button>
                                                    </div>
                                                    <textarea id="signature" class="form-textarea signature-textarea"
                                                        rows="4"
                                                        placeholder="Введите вашу подпись...">✨ Серебряный Волк мейн | UID: 700123456 | Всегда готов помочь!</textarea>
                                                </div>
                                                <div class="signature-preview">
                                                    <span class="preview-label">Предпросмотр:</span>
                                                    <div class="preview-content" id="signaturePreview">
                                                        ✨ Серебряный Волк мейн | UID: 700123456 | Всегда готов помочь!
                                                    </div>
                                                </div>
                                                <span class="form-hint">Максимум 200 символов. HTML-теги
                                                    запрещены.</span>
                                            </div>

                                            <div class="form-actions">
                                                <button type="submit" class="btn btn-primary">Сохранить подпись</button>
                                            </div>
                                        </form>
                                    </div>

                                    <!-- Forum Preferences -->
                                    <div class="section-card">
                                        <h3 class="card-title">Настройки отображения</h3>
                                        <div class="preferences-list">
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Показывать подпись</span>
                                                    <span class="preference-description">Отображать вашу подпись под
                                                        сообщениями</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Показывать онлайн-статус</span>
                                                    <span class="preference-description">Другие пользователи видят,
                                                        когда вы онлайн</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Показывать UID</span>
                                                    <span class="preference-description">Отображать ваш игровой UID в
                                                        профиле</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Разрешить личные сообщения</span>
                                                    <span class="preference-description">Позволить другим пользователям
                                                        писать вам в ЛС</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <!-- Tab: Notifications -->
                            <section id="notifications" class="profile-tab">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                                            </svg>
                                            Уведомления
                                        </h2>
                                    </div>

                                    <div class="section-card">
                                        <h3 class="card-title">Email уведомления</h3>
                                        <div class="preferences-list">
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Ответы на темы</span>
                                                    <span class="preference-description">Когда кто-то отвечает в ваших
                                                        темах</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Упоминания</span>
                                                    <span class="preference-description">Когда вас упоминают через
                                                        @username</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Личные сообщения</span>
                                                    <span class="preference-description">Когда вам пишут в личные
                                                        сообщения</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Новости форума</span>
                                                    <span class="preference-description">Важные объявления и
                                                        обновления</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox">
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="section-card">
                                        <h3 class="card-title">Push-уведомления</h3>
                                        <div class="preferences-list">
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Браузерные уведомления</span>
                                                    <span class="preference-description">Получать уведомления в
                                                        браузере</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox">
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                            <div class="preference-item">
                                                <div class="preference-info">
                                                    <span class="preference-title">Звук уведомлений</span>
                                                    <span class="preference-description">Воспроизводить звук при новых
                                                        уведомлениях</span>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" checked>
                                                    <span class="toggle-slider"></span>
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            <!-- Tab: Socials -->
                            <section id="socials" class="profile-tab">
                                <div class="profile-section">
                                    <div class="section-header">
                                        <h2 class="section-title">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path
                                                    d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                                                <rect x="2" y="9" width="4" height="12" />
                                                <circle cx="4" cy="4" r="2" />
                                            </svg>
                                            Привязка соцсетей
                                        </h2>
                                    </div>

                                    <div class="section-card">
                                        <div class="socials-grid">
                                            <!-- Discord -->
                                            <div class="social-card connected">
                                                <div class="social-icon discord">
                                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                                        <path
                                                            d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
                                                    </svg>
                                                </div>
                                                <div class="social-info">
