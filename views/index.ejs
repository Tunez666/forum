<%- include('partials/head') %>
<body>
   <div class="bg-layer">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-lines"></div>
  </div>

  <%- include('partials/header') %>

  <main class="main">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="pulse"></span>
          Версия 4.0 уже здесь!
        </div>
        <h1 class="hero-title">
          <span class="glitch" data-text="Добро пожаловать">Добро пожаловать</span>
          <br>на борт <span class="highlight">Звездного Экспресса</span>
        </h1>
        <p class="hero-desc">
          Сообщество Honkai Star Rail. 
          Обсуждайте билды, делитесь стратегиями, находите друзей.
        </p>
        <div class="hero-stats">
          <!-- TODO: Динамическая статистика -->
          <div class="stat-item">
            <span class="stat-value"><%= usersCount %></span>
            <span class="stat-label">Участников</span>
          </div>
          <div class="stat-item">
            <span class="stat-value"><%= postsCount %></span>
            <span class="stat-label">Сообщений</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">1,247</span>
            <span class="stat-label">Онлайн</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-card floating">
          <!-- TODO: Изображение персонажа -->
          <div class="hero-card-placeholder">
            <img src="/img/spark.jpg">
            <span>Баннер персонажа</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Grid -->
    <div class="content-grid">
      <!-- Main Content -->
      <div class="content-main">
        <!-- Categories -->
        <section class="section">
          <div class="section-header">
            <h2 class="section-title">
              <span class="title-icon">&#9670;</span>
              Разделы форума
            </h2>
            <a href="#" class="section-link">Все разделы &rarr;</a>
          </div>

          <div class="categories-grid">
            <!-- TODO: Категории из БД -->
            <a href="#" class="category-card">
              <div class="category-icon" style="--accent: #ff6b9d;">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
              </div>
              <div class="category-info">
                <h3 class="category-name">Общее обсуждение</h3>
                <p class="category-desc">Новости, слухи и всё о HSR</p>
              </div>
              <div class="category-stats">
                <span>2,451 тем</span>
                <span>45.2K сообщений</span>
              </div>
              <div class="category-arrow">&rarr;</div>
            </a>

            <a href="#" class="category-card">
              <div class="category-icon" style="--accent: #a855f7;">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <div class="category-info">
                <h3 class="category-name">Персонажи и билды</h3>
                <p class="category-desc">Гайды, сборки, обсуждение героев</p>
              </div>
              <div class="category-stats">
                <span>1,892 тем</span>
                <span>38.7K сообщений</span>
              </div>
              <div class="category-arrow">&rarr;</div>
            </a>

            <a href="#" class="category-card">
              <div class="category-icon" style="--accent: #06b6d4;">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div class="category-info">
                <h3 class="category-name">Забытый Чертог</h3>
                <p class="category-desc">Эндгейм контент, стратегии</p>
              </div>
              <div class="category-stats">
                <span>876 тем</span>
                <span>21.3K сообщений</span>
              </div>
              <div class="category-arrow">&rarr;</div>
            </a>

            <a href="#" class="category-card">
              <div class="category-icon" style="--accent: #f59e0b;">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
              <div class="category-info">
                <h3 class="category-name">Творчество</h3>
                <p class="category-desc">Арты, косплей, фанфики</p>
              </div>
              <div class="category-stats">
                <span>3,104 тем</span>
                <span>52.1K сообщений</span>
              </div>
              <div class="category-arrow">&rarr;</div>
            </a>

            <a href="#" class="category-card">
              <div class="category-icon" style="--accent: #10b981;">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div class="category-info">
                <h3 class="category-name">Поиск команды</h3>
                <p class="category-desc">Найди напарников для игры</p>
              </div>
              <div class="category-stats">
                <span>654 тем</span>
                <span>8.9K сообщений</span>
              </div>
              <div class="category-arrow">&rarr;</div>
            </a>

            <a href="#" class="category-card">
              <div class="category-icon" style="--accent: #ec4899;">
                <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <div class="category-info">
                <h3 class="category-name">Оффтоп</h3>
                <p class="category-desc">Болталка, мемы, флуд</p>
              </div>
              <div class="category-stats">
                <span>5,721 тем</span>
                <span>89.4K сообщений</span>
              </div>
              <div class="category-arrow">&rarr;</div>
            </a>
          </div>
        </section>

        <!-- Latest Topics -->
        <section class="section">
          <div class="section-header">
            <h2 class="section-title">
              <span class="title-icon">&#9733;</span>
              Последние темы
            </h2>
            <div class="section-tabs">
              <button class="tab active">Новые</button>
              <button class="tab">Популярные</button>
              <button class="tab">Без ответа</button>
            </div>
          </div>

          <div class="topics-list">
            <!-- TODO: Темы из БД -->
            <article class="topic-card">
              <div class="topic-avatar">
                <!-- TODO: Аватар пользователя -->
                <div class="avatar-placeholder">S</div>
              </div>
              <div class="topic-content">
                <div class="topic-meta">
                  <span class="topic-category">Персонажи</span>
                  <span class="topic-badge hot">Горячее</span>
                </div>
                <h3 class="topic-title">
                  <a href="#">Firefly или Топаз? Кого крутить в 2.7 — подробный разбор</a>
                </h3>
                <p class="topic-excerpt">
                  Разбираю обеих девушек, их сильные и слабые стороны. Спойлер: ответ не так очевиден...
                </p>
                <div class="topic-footer">
                  <span class="topic-author">StarDust_Player</span>
                  <span class="topic-time">15 минут назад</span>
                  <span class="topic-replies">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    247
                  </span>
                </div>
              </div>
            </article>

            <article class="topic-card">
              <div class="topic-avatar">
                <div class="avatar-placeholder" style="--hue: 180;">K</div>
              </div>
              <div class="topic-content">
                <div class="topic-meta">
                  <span class="topic-category">Забытый Чертог</span>
                  <span class="topic-badge pinned">Закреплено</span>
                </div>
                <h3 class="topic-title">
                  <a href="#">[Гайд] Чертог Небытия 12 — все команды без 5* световых конусов</a>
                </h3>
                <p class="topic-excerpt">
                  Показываю как пройти весь 12 этаж только с бесплатными персонажами и конусами из магазина...
                </p>
                <div class="topic-footer">
                  <span class="topic-author">KafkaMains</span>
                  <span class="topic-time">2 часа назад</span>
                  <span class="topic-replies">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    89
                  </span>
                </div>
              </div>
            </article>

            <article class="topic-card">
              <div class="topic-avatar">
                <div class="avatar-placeholder" style="--hue: 45;">A</div>
              </div>
              <div class="topic-content">
                <div class="topic-meta">
                  <span class="topic-category">Творчество</span>
                </div>
                <h3 class="topic-title">
                  <a href="#">Нарисовала Робин в стиле арт-деко, делюсь процессом</a>
                </h3>
                <p class="topic-excerpt">
                  Потратила неделю на этот арт, очень горжусь результатом. Внутри поэтапный процесс...
                </p>
                <div class="topic-footer">
                  <span class="topic-author">ArtistMoon</span>
                  <span class="topic-time">4 часа назад</span>
                  <span class="topic-replies">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    156
                  </span>
                </div>
              </div>
            </article>

            <article class="topic-card">
              <div class="topic-avatar">
                <div class="avatar-placeholder" style="--hue: 270;">M</div>
              </div>
              <div class="topic-content">
                <div class="topic-meta">
                  <span class="topic-category">Общее</span>
                </div>
                <h3 class="topic-title">
                  <a href="#">Сколько примогемов накопили к 2.8? Делимся результатами!</a>
                </h3>
                <p class="topic-excerpt">
                  Интересно посмотреть кто сколько смог насобирать. Я сейчас на 47к, жду Джейд...
                </p>
                <div class="topic-footer">
                  <span class="topic-author">MarchSimp</span>
                  <span class="topic-time">6 часов назад</span>
                  <span class="topic-replies">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    312
                  </span>
                </div>
              </div>
            </article>

            <article class="topic-card">
              <div class="topic-avatar">
                <div class="avatar-placeholder" style="--hue: 330;">N</div>
              </div>
              <div class="topic-content">
                <div class="topic-meta">
                  <span class="topic-category">Поиск команды</span>
                </div>
                <h3 class="topic-title">
                  <a href="#">Ищу активную гильдию на EU сервере, AR 65+</a>
                </h3>
                <p class="topic-excerpt">
                  Играю каждый день, есть все 5* DPS, готов помогать новичкам и проходить контент...
                </p>
                <div class="topic-footer">
                  <span class="topic-author">NightOwl</span>
                  <span class="topic-time">8 часов назад</span>
                  <span class="topic-replies">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    24
                  </span>
                </div>
              </div>
            </article>
          </div>

          <a href="#" class="load-more">Показать больше тем</a>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="sidebar">
        <!-- Online Users -->
        <div class="sidebar-card">
          <h3 class="sidebar-title">
            <span class="online-dot"></span>
            Сейчас онлайн
          </h3>
          <!-- TODO: Онлайн пользователи из БД -->
          <div class="online-users">
            <div class="online-user">
              <div class="avatar-small">S</div>
              <span>StarDust</span>
            </div>
            <div class="online-user">
              <div class="avatar-small" style="--hue: 180;">K</div>
              <span>KafkaMains</span>
            </div>
            <div class="online-user">
              <div class="avatar-small" style="--hue: 45;">A</div>
              <span>ArtistMoon</span>
            </div>
            <div class="online-user">
              <div class="avatar-small" style="--hue: 270;">M</div>
              <span>MarchSimp</span>
            </div>
            <span class="online-more">+1,243 ещё</span>
          </div>
        </div>

        <!-- Top Contributors -->
        <div class="sidebar-card">
          <h3 class="sidebar-title">Топ участников</h3>
          <!-- TODO: Топ пользователей из БД -->
          <div class="leaderboard">
            <div class="leader-item">
              <span class="leader-rank gold">1</span>
              <div class="avatar-small">D</div>
              <span class="leader-name">DanHengIL</span>
              <span class="leader-score">15,847</span>
            </div>
            <div class="leader-item">
              <span class="leader-rank silver">2</span>
              <div class="avatar-small" style="--hue: 200;">B</div>
              <span class="leader-name">BladeMaster</span>
              <span class="leader-score">12,456</span>
            </div>
            <div class="leader-item">
              <span class="leader-rank bronze">3</span>
              <div class="avatar-small" style="--hue: 100;">S</div>
              <span class="leader-name">SilverWolf</span>
              <span class="leader-score">9,823</span>
            </div>
            <div class="leader-item">
              <span class="leader-rank">4</span>
              <div class="avatar-small" style="--hue: 300;">H</div>
              <span class="leader-name">HuohuoHeal</span>
              <span class="leader-score">8,156</span>
            </div>
            <div class="leader-item">
              <span class="leader-rank">5</span>
              <div class="avatar-small" style="--hue: 30;">J</div>
              <span class="leader-name">JingYuanFan</span>
              <span class="leader-score">7,429</span>
            </div>
          </div>
        </div>

        <!-- Upcoming Events -->
        <div class="sidebar-card">
          <h3 class="sidebar-title">Ближайшие события</h3>
          <!-- TODO: События из БД -->
          <div class="events-list">
            <div class="event-item">
              <div class="event-date">
                <span class="event-day">15</span>
                <span class="event-month">Мар</span>
              </div>
              <div class="event-info">
                <span class="event-name">Баннер Firefly</span>
                <span class="event-time">Осталось 3 дня</span>
              </div>
            </div>
            <div class="event-item">
              <div class="event-date">
                <span class="event-day">22</span>
                <span class="event-month">Мар</span>
              </div>
              <div class="event-info">
                <span class="event-name">Обновление 2.8</span>
                <span class="event-time">Через 10 дней</span>
              </div>
            </div>
            <div class="event-item">
              <div class="event-date">
                <span class="event-day">01</span>
                <span class="event-month">Апр</span>
              </div>
              <div class="event-info">
                <span class="event-name">Турнир гильдий</span>
                <span class="event-time">Через 20 дней</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Discord Widget -->
        <div class="sidebar-card discord-card">
          <div class="discord-header">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/>
            </svg>
            <span>Наш Discord</span>
          </div>
          <p class="discord-desc">Присоединяйся к 8,500+ игрокам</p>
          <a href="#" class="btn btn-discord">Присоединиться</a>
        </div>
      </aside>
    </div>
  </main>
</body>
<%- include('partials/footer') %>