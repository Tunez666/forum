<%- include('partials/head') %>
<body>
  <!-- Background -->
  <div class="bg-layer">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-lines"></div>
  </div>

<%- include('partials/header') %>

  <main class="topics-page">
    <div class="topics-container">
      <!-- Page Header -->
      <div class="topics-page-header">
        <div class="page-title-row">
          <h1 class="page-title">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            Все темы
          </h1>
          <% if (user) { %>
          <button class="create-btn" onclick="openCreateTopicModal()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 5v14M5 12h14"/>
            </svg>
            Создать тему
          </button>
          <% } %>
        </div>

        <!-- Filters -->
        <div class="topics-filters">
          <div class="filter-group">
            <label class="filter-label">Категория</label>
            <select class="filter-select" id="categoryFilter">
              <option value="">Все категории</option>
              <% categories.forEach(categorie=> { %>
              <option value="<%= categorie.id %>"> <%= categorie.name %> </option>
              <% }) %>
            </select>
          </div>
        
          <div class="filter-group">
            <label class="filter-label">Сортировка</label>
            <select class="filter-select" id="sortFilter">
              <option value="latest">Последние</option>
              <option value="popular">Популярные</option>
            </select>
          </div>
          <div class="filter-group search-group">
            <label class="filter-label">Поиск</label>
            <div class="search-input-wrapper">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input type="text" class="search-input" placeholder="Поиск по темам..." id="searchInput">
            </div>
          </div>
        </div>
      </div>

      <!-- Topics List -->
      <div class="topics-list-container">
        <div class="topics-list-header">
          <span class="header-cell topic-cell">Тема</span>
          <span class="header-cell category-cell">Категория</span>
          <span class="header-cell replies-cell">Ответы</span>
          <span class="header-cell replies-cell"></span>
          <span class="header-cell activity-cell">Автор</span>
        </div>

        <div class="topics-list-body">
                
          <!-- Regular Topics -->
           <% selectTopics.forEach(topic=> { %>
          <div class="topic-list-row">
            <div class="topic-cell">
              <div class="topic-avatar">
                <div class="avatar-circle" style="--hue: 45;"><%= topic.title[0].toUpperCase() %></div>
              </div>
              <div class="topic-main-info">
                <a href="/topic/<%= topic.id %>" class="topic-title-text"><%= topic.title %></a>
                <div class="topic-meta-row">
                  <div class="topic-badges">
                    <span class="topic-category-badge" style="--cat-color: #f755a6;"><%= topic.description %></span>
                  </div>
                </div>
              </div>
            </div>
            <div class="category-cell">
              <span class="category-tag" style="--cat-color: #f59e0b;"><%= topic.category_name %></span>
            </div>
            <div class="replies-cell">
              <span class="stat-number"><%= topic.posts_count %></span>
            </div>
            <div class="activity-cell">
              <div class="last-activity">
               
              </div>
            </div>
            <div class="activity-cell">
              <div class="last-activity">
                <div class="last-user-avatar" style="--hue: 330;"><%= topic.author_name[0].toUpperCase() %></div>
                <span class="last-activity-time"><%= new Date(topic.created_at).toLocaleString('ru-RU') %></span>
              </div>
            </div>

            
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Pagination -->
      <div class="pagination-container">
        <div class="pagination-info">
          Показано 1-12 из 12,847 тем
        </div>
        <div class="pagination-controls">
          <button class="pagination-btn disabled">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <button class="pagination-btn active">1</button>
          <button class="pagination-btn">2</button>
          <button class="pagination-btn">3</button>
          <span class="pagination-dots">...</span>
          <button class="pagination-btn">1071</button>
          <button class="pagination-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </div>
        <div class="per-page-selector">
          <span>Показывать:</span>
          <select class="per-page-select">
            <option value="12" selected>12</option>
            <option value="24">24</option>
            <option value="48">48</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Add Event Modal -->
  <div class="modal-overlay" id="topic-modal" onclick="closeModalOnOverlay(event)">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">Добавить событие</h3>
        <button class="modal-close" onclick="closeCreateTopicModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
      <form id="topic-form" method = 'POST' action = '/modalCreateTopic'>
        
        <div class="form-group">
          <label for="event-name">Название топика</label>
          <input 
            type="text" 
            id="title" 
            name="title" 
            class="form-input"
            required
          >
        </div>

        <div class="form-group">
          <label for="event-name">Описание</label>
          <input 
            type="text" 
            id="description" 
            name="description" 
            class="form-input"
            required
          >
        </div>

        <div class="form-group">
                  <label for="category-parent">Категория</label>
                  <select id="category-parent-add" name="category_id" class="form-input">
                    <% categories.forEach(categorie=> { %>
                      <option value="<%= categorie.id %>">
                        <%= categorie.name %>
                      </option>
                      <% }) %>
                  </select>
                </div>
        
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span id="modal-submit-text">Создать</span>
          </button>
          <button type="button" class="btn btn-secondary" onclick="closeCreateTopicModal()">
            Отмена
          </button>
        </div>
      </form>
    </div>
  </div>
  </main>

  <%- include('partials/footer') %>